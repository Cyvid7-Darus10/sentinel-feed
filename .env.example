# Required — Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Required — Secret for authenticating cron job requests (use: openssl rand -base64 32)
CRON_SECRET=change-me-use-openssl-rand-base64-32

# Optional — Enables AI-powered summaries and relevance filtering
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional — Set to "false" to disable AI enrichment entirely (default: enabled)
ENABLE_AI_ENRICHMENT=true
